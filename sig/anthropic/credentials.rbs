module Anthropic
  module Credentials
    GRANT_TYPE_JWT_BEARER: String
    GRANT_TYPE_REFRESH_TOKEN: String
    TOKEN_ENDPOINT: String
    TOKEN_EXCHANGE_TIMEOUT: Integer
    OAUTH_API_BETA_HEADER: String
    FEDERATION_BETA_HEADER: String
    ADVISORY_REFRESH_SECONDS: Integer
    MANDATORY_REFRESH_SECONDS: Integer
    DEFAULT_PROFILE: String
    DEFAULT_BASE_URL: String
    ENV_API_KEY: String
    ENV_AUTH_TOKEN: String
    ENV_BASE_URL: String
    ENV_CONFIG_DIR: String
    ENV_PROFILE: String
    ENV_IDENTITY_TOKEN: String
    ENV_IDENTITY_TOKEN_FILE: String
    ENV_FEDERATION_RULE_ID: String
    ENV_ORGANIZATION_ID: String
    ENV_SERVICE_ACCOUNT_ID: String
    ENV_SCOPE: String
    AUTH_TYPE_OIDC_FEDERATION: String
    AUTH_TYPE_USER_OAUTH: String

    def self.config_dir: -> Pathname
    def self.read_active_config_pointer: -> String?
    def self.active_profile: -> String
    def self.config_file_path: (String profile) -> Pathname
    def self.active_profile_config?: -> bool
    def self.explicit_active_config?: -> bool
    def self.resolve_identity_token_path: (?String? path) -> Pathname?
    def self.auto_discoverable_credentials?: -> bool
    def self.default_credentials: (?String base_url) -> CredentialResult?

    class AccessToken
      attr_reader token: String
      attr_reader expires_at: Integer?

      def initialize: (token: String, ?expires_at: Integer?) -> void
      def hash: -> Integer
    end

    class StaticToken
      @token: String

      def initialize: (String token) -> void
      def call: (?force_refresh: bool) -> AccessToken
    end

    class IdentityTokenFile
      attr_reader path: Pathname

      @path: Pathname

      def initialize: (?String? path) -> void
      def call: -> String

      private

      def resolve_path: (String? explicit) -> String?
    end

    class TokenCache
      ADVISORY_REFRESH_BACKOFF_SECONDS: Integer

      @provider: _AccessTokenProvider
      @advisory: Integer
      @mandatory: Integer
      @time_source: ^-> Float
      @lock: top
      @cached: AccessToken?
      @refresh_in_progress: bool
      @refresh_condition: top
      @next_force: bool
      @last_advisory_failure_time: Float

      def initialize: (
        _AccessTokenProvider provider,
        ?advisory_refresh_seconds: Integer,
        ?mandatory_refresh_seconds: Integer,
        ?time_source: ^-> Float
      ) -> void

      def get_token: -> String
      def invalidate: -> void

      private

      def invoke_provider: (force: bool) -> AccessToken
    end

    class WorkloadIdentityError < Anthropic::Errors::Error
      attr_reader status_code: Integer?
      attr_reader body: (Hash[Symbol, untyped] | String)?
      attr_reader request_id: String?

      def initialize: (
        String message,
        ?status_code: Integer?,
        ?body: (Hash[Symbol, untyped] | String)?,
        ?request_id: String?
      ) -> void

      def to_s: -> String
    end

    class WorkloadIdentity
      MAX_ASSERTION_BYTES: Integer

      @identity_token_provider: _IdentityTokenProvider
      @federation_rule_id: String
      @organization_id: String
      @service_account_id: String?
      @scope: String?
      @bound_base_url: String?

      def initialize: (
        identity_token_provider: _IdentityTokenProvider,
        federation_rule_id: String,
        organization_id: String,
        ?service_account_id: String?,
        ?scope: String?
      ) -> void

      def bind_base_url: (String base_url) -> void
      def call: (?force_refresh: bool) -> AccessToken

      private

      def base_url: -> String
      def perform_exchange: (String jwt) -> AccessToken
      def handle_error_response: (top response, String? request_id) -> bot
    end

    class ConfigProvider
      @config: Hash[Symbol, untyped]?
      @credentials_path: Pathname?
      @base_url: String?
      @bound_base_url: String?
      @workload_delegate: WorkloadIdentity?

      def call: (?force_refresh: bool) -> AccessToken
      def resolved_base_url: -> String?
      def bind_base_url: (String base_url) -> void
      def extra_headers: -> Hash[String, String]

      private

      def load_config: -> Hash[Symbol, untyped]
      def config_source: -> untyped
      def resolve_base_url: (Hash[Symbol, untyped] config) -> String
      def fill_missing_from_env: (
        Hash[Symbol, untyped] config,
        Hash[Symbol, untyped] auth
      ) -> void
      def fill: (
        Hash[Symbol, untyped] target,
        Symbol key,
        String env_var
      ) -> void
      def auth_block: -> Hash[Symbol, untyped]
      def call_oidc_federation: (
        Hash[Symbol, untyped] auth,
        force_refresh: bool
      ) -> AccessToken
      def call_user_oauth: (
        Hash[Symbol, untyped] auth,
        force_refresh: bool
      ) -> AccessToken
      def build_workload_delegate: (
        Hash[Symbol, untyped] auth
      ) -> WorkloadIdentity
      def resolve_identity_token_provider: (
        Hash[Symbol, untyped] auth
      ) -> _IdentityTokenProvider
      def read_credentials: -> Hash[String, untyped]
      def read_credentials_if_exists: -> Hash[String, untyped]?
      def write_credentials: (Hash[String, untyped] data) -> void
      def coerce_expires_at: (untyped value) -> Integer?
    end

    class CredentialsFile < ConfigProvider
      attr_reader profile: String
      attr_reader config_path: Pathname

      @profile: String
      @config_path: Pathname

      def initialize: (?String? profile) -> void

      private

      def resolve_profile: -> String
      def config_dir: -> Pathname
      def config_file_path: (String profile) -> Pathname
      def credentials_file_path: (String profile) -> Pathname
    end

    class InMemoryConfig < ConfigProvider
      @raw_config: Hash[String, untyped]
      @identity_token_provider_override: _IdentityTokenProvider?

      def initialize: (
        Hash[String, untyped] config,
        ?identity_token_provider: _IdentityTokenProvider?
      ) -> void

      def config_path: -> nil

      private

      def load_config: -> Hash[Symbol, untyped]
      def build_workload_delegate: (
        Hash[Symbol, untyped] auth
      ) -> WorkloadIdentity
    end

    class CredentialResult
      attr_reader provider: untyped
      attr_reader extra_headers: Hash[String, String]
      attr_reader base_url: String?

      def initialize: (
        untyped provider,
        ?extra_headers: Hash[String, String],
        ?base_url: String?
      ) -> void
    end

    interface _AccessTokenProvider
      def call: (?force_refresh: bool) -> AccessToken
    end

    interface _IdentityTokenProvider
      def call: -> String
    end
  end
end
