module Anthropic
  module Models
    module Beta
      module Sessions
        type resource_list_params =
          {
            session_id: String,
            limit: Integer,
            page: String,
            betas: ::Array[Anthropic::Models::anthropic_beta]
          }
          & Anthropic::Internal::Type::request_parameters

        class ResourceListParams < Anthropic::Internal::Type::BaseModel
          extend Anthropic::Internal::Type::RequestParameters::Converter
          include Anthropic::Internal::Type::RequestParameters

          attr_accessor session_id: String

          attr_reader limit: Integer?

          def limit=: (Integer) -> Integer

          attr_reader page: String?

          def page=: (String) -> String

          attr_reader betas: ::Array[Anthropic::Models::anthropic_beta]?

          def betas=: (
            ::Array[Anthropic::Models::anthropic_beta]
          ) -> ::Array[Anthropic::Models::anthropic_beta]

          def initialize: (
            session_id: String,
            ?limit: Integer,
            ?page: String,
            ?betas: ::Array[Anthropic::Models::anthropic_beta],
            ?request_options: Anthropic::request_opts
          ) -> void

          def to_hash: -> {
            session_id: String,
            limit: Integer,
            page: String,
            betas: ::Array[Anthropic::Models::anthropic_beta],
            request_options: Anthropic::RequestOptions
          }
        end
      end
    end
  end
end
