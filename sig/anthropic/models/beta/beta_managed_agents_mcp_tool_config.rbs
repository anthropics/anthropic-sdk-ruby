module Anthropic
  module Models
    class BetaManagedAgentsMCPToolConfig = Beta::BetaManagedAgentsMCPToolConfig

    module Beta
      type beta_managed_agents_mcp_tool_config =
        {
          enabled: bool,
          name: String,
          permission_policy: Anthropic::Models::Beta::BetaManagedAgentsMCPToolConfig::permission_policy
        }

      class BetaManagedAgentsMCPToolConfig < Anthropic::Internal::Type::BaseModel
        attr_accessor enabled: bool

        attr_accessor name: String

        attr_accessor permission_policy: Anthropic::Models::Beta::BetaManagedAgentsMCPToolConfig::permission_policy

        def initialize: (
          enabled: bool,
          name: String,
          permission_policy: Anthropic::Models::Beta::BetaManagedAgentsMCPToolConfig::permission_policy
        ) -> void

        def to_hash: -> {
          enabled: bool,
          name: String,
          permission_policy: Anthropic::Models::Beta::BetaManagedAgentsMCPToolConfig::permission_policy
        }

        type permission_policy =
          Anthropic::Beta::BetaManagedAgentsAlwaysAllowPolicy
          | Anthropic::Beta::BetaManagedAgentsAlwaysAskPolicy

        module PermissionPolicy
          extend Anthropic::Internal::Type::Union

          def self?.variants: -> ::Array[Anthropic::Models::Beta::BetaManagedAgentsMCPToolConfig::permission_policy]
        end
      end
    end
  end
end
